{
  "name": "n8n-nodes-ordify",
  "version": "0.1.15",
  "description": "n8n community node for Ordify A2A and Jobs APIs",
  "license": "MIT",
  "author": {
    "name": "Denys",
    "email": "denys@ordify.ai",
    "url": "https://ordify.ai"
  },
  "homepage": "https://ordify.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ordify-Ai/ordify-n8n.git"
  },
  "bugs": {
    "url": "https://github.com/Ordify-Ai/ordify-n8n/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ordify",
    "automation",
    "a2a"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp nodes/Ordify/Ordify_icon_transparent.png dist/nodes/Ordify/Ordify_icon_transparent.png && cp credentials/Ordify_icon_transparent.png dist/credentials/Ordify_icon_transparent.png",
    "dev": "tsc -w",
    "lint": "eslint credentials nodes utils index.ts --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.10",
    "pnpm": ">=8"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/OrdifyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Ordify/Ordify.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "n8n-workflow": "^1.76.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
